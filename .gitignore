# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Conteúdo editado pelo admin. O que o repositório versiona é o ponto de
# partida, em src/data/seed/ — isto aqui é o estado vivo de cada máquina.
/conteudo/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Endereço do servidor de publicação — fora do git, o repo é público.
/deploy/servidor.local
